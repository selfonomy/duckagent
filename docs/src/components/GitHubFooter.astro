---
const githubUrl = 'https://github.com/selfonomy/duckagent';
---

<footer class="duckagent-footer" aria-label="DuckAgent site footer">
  <div class="footer-inner">
    <a class="github-link" href={githubUrl} target="_blank" rel="noreferrer">
      <svg aria-hidden="true" viewBox="0 0 24 24" width="18" height="18">
        <path
          fill="currentColor"
          d="M12 .3a12 12 0 0 0-3.8 23.38c.6.12.83-.26.83-.57L9 21.07c-3.34.72-4.04-1.61-4.04-1.61-.55-1.39-1.34-1.76-1.34-1.76-1.08-.74.09-.73.09-.73 1.2.09 1.83 1.24 1.83 1.24 1.08 1.83 2.81 1.3 3.5 1 .1-.78.42-1.31.76-1.61-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.14-.3-.54-1.52.1-3.18 0 0 1-.32 3.3 1.23a11.5 11.5 0 0 1 6 0c2.28-1.55 3.29-1.23 3.29-1.23.64 1.66.24 2.88.12 3.18a4.65 4.65 0 0 1 1.23 3.22c0 4.61-2.8 5.63-5.48 5.92.42.36.81 1.1.81 2.22l-.01 3.29c0 .31.2.69.82.57A12 12 0 0 0 12 .3Z"
        ></path>
      </svg>
      <span>selfonomy/duckagent</span>
    </a>
  </div>
</footer>

<style>
  .duckagent-footer {
    background: #05060a;
    color: rgba(247, 239, 224, 0.66);
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    max-width: 1240px;
    margin: 0 auto;
    padding: 22px clamp(20px, 5vw, 72px);
  }

  .github-link {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    color: inherit;
    font-size: 0.82rem;
    font-weight: 760;
    line-height: 1;
    text-decoration: none;
  }

  .github-link:hover,
  .github-link:focus {
    color: #fef3c7;
  }

  .github-link svg {
    flex: 0 0 auto;
  }
</style>
